<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApp.CompletedPage"
             Title="Completed"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto, *">
        
        <Label Grid.Row="0" Text="Completed Tasks" FontSize="18" FontAttributes="Bold" TextColor="#D3D3D3" HorizontalOptions="Center" Margin="0,15,0,15" />
        <BoxView Grid.Row="0" HeightRequest="1" Color="#F0F0F0" VerticalOptions="End"/>

        <ListView x:Name="completedLV"
                  Grid.Row="1" 
                  SeparatorVisibility="None"
                  HasUnevenRows="True"
                  SelectionMode="None"
                  Margin="15,10,15,0">
            
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Border Margin="0,5,0,5" Padding="15,12" Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#FAFAFA">
                            <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                            
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15">
                                <Label Text="{Binding title}" VerticalOptions="Center" TextColor="#A0A0A0" FontSize="16" TextDecorations="Strikethrough"/>
                                
                                <Label Grid.Column="1" Text="🗑️" VerticalOptions="Center" FontSize="18">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDeleteTapped" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ContentPage>