<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ToDoApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ToDoApp"
    xmlns:views="clr-namespace:ToDoApp.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        
        <Tab Title="ToDo">
            <Tab.Icon>
                <FontImageSource FontFamily="OpenSansRegular" Glyph="📋" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>

        <Tab Title="Completed">
            <Tab.Icon>
                <FontImageSource FontFamily="OpenSansRegular" Glyph="✔️" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate local:CompletedPage}" />
        </Tab>

        <Tab Title="Profile">
            <Tab.Icon>
                <FontImageSource FontFamily="OpenSansRegular" Glyph="👤" />
            </Tab.Icon>
            <ShellContent ContentTemplate="{DataTemplate views:LoginPage}" />
        </Tab>

    </TabBar>

</Shell>